# Core platform
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@host:5432/database
CRON_SECRET=replace-with-strong-random-secret

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

# API / webhook auth secrets
LIFECYCLEOS_API_KEY=replace-with-api-key
WEBHOOK_SECRET=replace-with-webhook-secret

# Email tracking + sender identity
EMAIL_TRACKING_SECRET=replace-with-long-random-secret
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=LifecycleOS
EMAIL_REPLY_TO=support@example.com
EMAIL_RATE_LIMIT=10

# SMTP transport (if using SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
SMTP_POOL_SIZE=5

# AWS SES transport / domain verification (if using SES)
AWS_REGION=us-east-1
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
SES_CONFIGURATION_SET=
PLATFORM_SENDING_DOMAIN=mail.example.com

# DKIM signing
DKIM_DOMAIN=example.com
DKIM_SELECTOR=lifecycleos
DKIM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# CORS
CORS_ALLOWED_ORIGINS=https://app.example.com,https://sdk.example.com

# Platform-provided runtime values (usually auto-injected on Vercel)
VERCEL_URL=
VERCEL_PROJECT_PRODUCTION_URL=
